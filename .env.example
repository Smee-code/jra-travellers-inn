SECRET_KEY=change-this-to-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-render-service.onrender.com
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
DATABASE_SSL_REQUIRE=True
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-render-service.onrender.com,https://your-vercel-app.vercel.app
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=3600
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
VITE_API_BASE_URL=https://your-render-service.onrender.com/api
WEBPUSH_VAPID_PUBLIC_KEY=your-public-application-server-key
WEBPUSH_VAPID_PRIVATE_KEY=your-private-application-server-key
WEBPUSH_VAPID_SUBJECT=mailto:stay@travellersinn.ph
